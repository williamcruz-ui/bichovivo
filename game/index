<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>BichoVivo — Tamagotchi Game</title>
  <script crossorigin src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
  <script crossorigin src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
  <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body { font-family: ui-rounded, 'SF Pro Rounded', -apple-system, 'Segoe UI', system-ui, sans-serif; -webkit-font-smoothing: antialiased; overflow-x: hidden; }
    img, svg { display: block; max-width: 100%; }
    a { color: inherit; }
    ul { list-style: none; }
    button { font-family: inherit; cursor: pointer; }
    
    @keyframes breathe { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.04); } }
    @keyframes sway { 0%, 100% { transform: rotate(-2deg); } 50% { transform: rotate(2deg); } }
    @keyframes blink { 0%, 92%, 100% { transform: scaleY(1); } 96% { transform: scaleY(0.08); } }
    @keyframes float-emote { 0% { transform: translateX(-50%) translateY(0) scale(0.7); opacity: 0; } 15% { opacity: 1; } 100% { transform: translateX(-50%) translateY(-82px) scale(1.5); opacity: 0; } }
    
    .bv-root { font-family: ui-rounded, 'SF Pro Rounded', -apple-system, 'Segoe UI', system-ui, sans-serif; }
    .bv-breathe { animation: breathe 3.4s ease-in-out infinite; transform-origin: 50% 78%; }
    .bv-sway { animation: sway 5s ease-in-out infinite; transform-origin: 50% 92%; }
    .bv-emote { animation: float-emote 1.3s ease-out forwards; }
    .bv-btn { transition: transform 0.08s ease; }
    .bv-btn:active { transform: scale(0.92); }
    .bv-btn:disabled { filter: grayscale(0.6) opacity(0.5); }
  </style>
</head>
<body>
  <div id="root"></div>

  <script type="text/babel">
    const { useState, useEffect, useRef, useCallback } = React;

    const INITIAL = { saciedade: 80, felicidade: 75, energia: 90, higiene: 85, saude: 90 };
    const STORAGE_KEY = "bichovivo:save:v1";
    const clamp = (v) => Math.max(0, Math.min(100, Math.round(v)));

    const TEMPERS = {
      "Brincalhão": { emoji: "🎈", play: 1.5, happyDecay: 1.3, anger: 1.0, calm: 1.0 },
      "Tranquilo":  { emoji: "😌", play: 1.0, happyDecay: 0.7, anger: 0.6, calm: 1.2 },
      "Resmungão":  { emoji: "😤", play: 0.9, happyDecay: 1.2, anger: 1.6, calm: 0.8 },
      "Carente":    { emoji: "🥺", play: 1.1, happyDecay: 1.5, anger: 1.0, calm: 1.5 },
    };
    const TEMPER_KEYS = Object.keys(TEMPERS);
    const pickTemper = () => TEMPER_KEYS[Math.floor(Math.random() * TEMPER_KEYS.length)];

    const MOOD_MSG = {
      ok: "Tá de boa 😌", happy: "Super feliz! 🥰", hungry: "Tô com fominha… 🍽️",
      dirty: "Preciso de um banho 🫧", sad: "Brinca comigo? 🥺", sick: "Não tô bem… 🤒",
      sleep: "Zzz… dormindo 💤", ko: "Desmaiei… 😵", angry: "Grr… me deixa! 😠",
    };

    function Creature({ mood, saude, stage }) {
      const angry = mood === "angry";
      const c = angry ? { body: "#FF9E8A", accent: "#E8705A", belly: "#FFE3DA" }
        : mood === "ko" ? { body: "#C7C2BC", accent: "#A39E98", belly: "#E9EFE1" }
        : saude < 35 ? { body: "#CFD8C0", accent: "#A8B49A", belly: "#E9EFE1" }
        : saude < 60 ? { body: "#F0D3A6", accent: "#D99B57", belly: "#FFF1DC" }
        : { body: "#FFD79F", accent: "#F2A65A", belly: "#FFF1DC" };

      const dark = "#3a3350";

      return (
        <svg width="200" height="200" viewBox="0 0 200 200" className="bv-sway">
          <g className="bv-breathe">
            <ellipse cx="78" cy="168" rx="16" ry="10" fill={c.accent} />
            <ellipse cx="122" cy="168" rx="16" ry="10" fill={c.accent} />
            <ellipse cx="100" cy="112" rx="62" ry="58" fill={c.body} />
            <ellipse cx="100" cy="126" rx="40" ry="34" fill={c.belly} opacity="0.9" />
            <ellipse cx="44" cy="120" rx="11" ry="15" fill={c.body} />
            <ellipse cx="156" cy="120" rx="11" ry="15" fill={c.body} />
            <ellipse cx="80" cy="104" rx="8.5" ry="10" fill={dark} />
            <ellipse cx="120" cy="104" rx="8.5" ry="10" fill={dark} />
            <path d="M87 130 Q100 141 113 130" stroke={dark} strokeWidth="3.5" fill="none" strokeLinecap="round" />
          </g>
        </svg>
      );
    }

    function StatPill({ icon, value, hue }) {
      const color = value < 25 ? "#E8657A" : value < 50 ? "#E8A33C" : hue;
      return (
        <div style={{ display: "flex", alignItems: "center", gap: "6px", fontSize: "12px" }}>
          <span>{icon}</span>
          <div style={{ width: 34, height: 6, borderRadius: 99, background: "rgba(0,0,0,0.10)" }}>
            <div style={{ width: `${value}%`, height: "100%", borderRadius: 99, background: color, transition: "width .4s ease" }} />
          </div>
        </div>
      );
    }

    function DeviceButton({ icon, label, color, onClick, disabled }) {
      return (
        <button onClick={onClick} disabled={disabled} className="bv-btn" style={{
          display: "flex", flexDirection: "column", alignItems: "center", justifyContent: "center", gap: "8px",
          padding: "10px", borderRadius: "16px", background: "rgba(255,255,255,0.16)", border: "none",
          color: "#fff", fontSize: "11px", fontWeight: 700, cursor: disabled ? "not-allowed" : "pointer", opacity: disabled ? 0.5 : 1
        }}>
          <div style={{ width: 38, height: 38, borderRadius: "50%", background: color, display: "flex", alignItems: "center", justifyContent: "center", fontSize: "19px" }}>
            {icon}
          </div>
          <span>{label}</span>
        </button>
      );
    }

    export default function BichoVivo() {
      const [stats, setStats] = useState(INITIAL);
      const [name, setName] = useState("Pix");
      const [createdAt, setCreatedAt] = useState(Date.now());
      const [sleeping, setSleeping] = useState(false);
      const [alive, setAlive] = useState(true);
      const [nowTs, setNowTs] = useState(Date.now());
      const [emotes, setEmotes] = useState([]);
      const [msg, setMsg] = useState(null);
      const [irrit, setIrrit] = useState(0);
      const [isAngry, setIsAngry] = useState(false);
      const [temperament, setTemperament] = useState(pickTemper());

      const temper = TEMPERS[temperament] || TEMPERS["Tranquilo"];
      const ageS = Math.max(0, Math.floor((nowTs - createdAt) / 1000));
      const stage = { scale: 1.0 };

      let displayMood = !alive ? "ko" : isAngry ? "angry" : sleeping ? "sleep" : stats.saciedade < 20 ? "hungry" : stats.felicidade > 75 ? "happy" : "ok";

      const addEmote = useCallback((char) => {
        const id = Date.now() + Math.random();
        setEmotes((e) => [...e, { id, char, x: (Math.random() * 16 - 8).toFixed(0) }]);
        setTimeout(() => setEmotes((e) => e.filter((it) => it.id !== id)), 1300);
      }, []);

      const showMsg = useCallback((text) => {
        const id = Date.now();
        setMsg({ text, id });
        setTimeout(() => setMsg((m) => (m && m.id === id ? null : m)), 2200);
      }, []);

      const bump = (patch) => {
        setStats((s) => {
          const n = { ...s };
          for (const k in patch) n[k] = clamp((s[k] || 0) + patch[k]);
          return n;
        });
      };

      useEffect(() => {
        const id = setInterval(() => setNowTs(Date.now()), 1000);
        return () => clearInterval(id);
      }, []);

      useEffect(() => {
        if (!alive) return;
        const id = setInterval(() => {
          setStats((s) => {
            let n = { ...s };
            if (sleeping) {
              n.energia = clamp(s.energia + 6);
              n.saciedade = clamp(s.saciedade - 1);
            } else {
              n.saciedade = clamp(s.saciedade - 2);
              n.felicidade = clamp(s.felicidade - 1 * temper.happyDecay);
              n.energia = clamp(s.energia - 1.5);
              n.higiene = clamp(s.higiene - 1);
            }
            if (n.saude <= 0) {
              n.saude = 0;
              setAlive(false);
            }
            return n;
          });
        }, 3000);
        return () => clearInterval(id);
      }, [sleeping, alive, temper]);

      const feed = () => {
        if (!alive || sleeping) return;
        if (stats.saciedade >= 98) return showMsg("Já está cheio! 🍃");
        bump({ saciedade: 25, felicidade: 3 });
        addEmote("🍎");
        showMsg("Hmmm, que delícia! 😋");
      };

      const playGame = () => {
        if (!alive || sleeping) return;
        if (stats.energia < 12) return showMsg("Muito cansado 😴");
        bump({ felicidade: 20 * temper.play, energia: -12, saciedade: -6 });
        addEmote("⚽");
        showMsg("Yuhuu! 🎉");
      };

      const clean = () => {
        if (!alive || sleeping) return;
        bump({ higiene: 35, felicidade: 3 });
        addEmote("🫧");
        showMsg("Tão limpinho! ✨");
      };

      const pet = () => {
        if (!alive || sleeping) return;
        bump({ felicidade: 12 });
        addEmote("💕");
        showMsg(isAngry ? "Calma… tá tudo bem 🥺" : "Ronrom 🥰");
      };

      const toggleSleep = () => {
        if (!alive) return;
        const going = !sleeping;
        setSleeping(going);
        showMsg(going ? "Boa noite… 💤" : "Bom dia! ☀️");
      };

      const restart = () => {
        setStats(INITIAL);
        setAlive(true);
        setSleeping(false);
        setIrrit(0);
        setIsAngry(false);
        setCreatedAt(Date.now());
        setTemperament(pickTemper());
        showMsg("Um novo começo! 🌱");
      };

      const busy = sleeping || !alive;

      return (
        <div className="bv-root" style={{
          minHeight: "100vh", width: "100%", display: "flex", alignItems: "center", justifyContent: "center",
          padding: "16px", background: "linear-gradient(180deg,#C3B5FF 0%,#E9C7FF 45%,#FFD9C2 100%)", overflow: "hidden"
        }}>
          <div style={{ width: "100%", maxWidth: 380 }}>
            <div style={{
              background: "linear-gradient(160deg,#8B7BF0 0%,#6C5CE7 100%)", borderRadius: "46px 46px 40px 40px",
              padding: 18, boxShadow: "0 24px 60px rgba(76,60,160,0.45)"
            }}>
              <div style={{
                display: "flex", alignItems: "center", justifyContent: "space-between", marginBottom: 16,
                paddingBottom: 16, borderBottom: "1px solid rgba(255,255,255,0.1)"
              }}>
                <div style={{ display: "flex", alignItems: "center", gap: 8 }}>
                  <span style={{ width: 8, height: 8, borderRadius: "50%", background: "#FFD24D" }} />
                  <span style={{ color: "#fff", fontWeight: 900, letterSpacing: "1.5px", fontSize: 13 }}>BICHOVIVO</span>
                  <span style={{ width: 8, height: 8, borderRadius: "50%", background: "#FF8FA3" }} />
                </div>
              </div>

              <div style={{
                borderRadius: 30, background: "linear-gradient(180deg,#EAF7F0 0%,#FBF4E7 100%)",
                boxShadow: "inset 0 3px 14px rgba(0,0,0,0.18)", border: "3px solid rgba(0,0,0,0.10)",
                minHeight: 320, display: "flex", flexDirection: "column", alignItems: "center", padding: "16px"
              }}>
                <div style={{ display: "flex", flexDirection: "column", alignItems: "flex-start", gap: 8, marginBottom: 16, width: "100%" }}>
                  <div style={{ fontSize: 17, fontWeight: 900, color: "#3a3350" }}>{name}</div>
                  <span style={{
                    fontSize: 10.5, fontWeight: 700, color: "#6C5CE7", background: "rgba(108,92,231,0.12)",
                    borderRadius: "50%", padding: "4px 12px"
                  }}>{temper.emoji} {temperament}</span>
                </div>

                <div style={{ flex: 1, display: "flex", alignItems: "center", justifyContent: "center", width: "100%" }}>
                  <div style={{ transform: `scale(${stage.scale})`, cursor: "pointer" }} onClick={() => addEmote("💗")}>
                    <Creature mood={displayMood} saude={stats.saude} stage={stage} />
                  </div>
                  {emotes.map((e) => (
                    <span key={e.id} className="bv-emote" style={{
                      position: "absolute", bottom: 70, left: `calc(50% + ${e.x}px)`, fontSize: 26
                    }}>{e.char}</span>
                  ))}
                </div>

                <div style={{ borderRadius: "50%", padding: "6px 12px", marginTop: 12, background: "rgba(108,92,231,0.10)" }}>
                  <span style={{ fontSize: 12.5, fontWeight: 700, color: "#5a5270" }}>{msg ? msg.text : MOOD_MSG[displayMood]}</span>
                </div>

                {!alive && (
                  <div style={{
                    position: "absolute", inset: 0, display: "flex", flexDirection: "column", alignItems: "center",
                    justifyContent: "center", textAlign: "center", background: "rgba(28,22,58,0.82)", borderRadius: 27
                  }}>
                    <div style={{ fontSize: 40 }}>😵</div>
                    <div style={{ color: "#fff", fontWeight: 900, fontSize: 17, marginTop: 16 }}>{name} desmaiou!</div>
                    <button onClick={restart} style={{
                      marginTop: 24, borderRadius: "50%", padding: "10px 20px", background: "#7CF5D0",
                      color: "#0f3b30", fontWeight: 800, fontSize: 14, border: "none", cursor: "pointer"
                    }}>🌱 Recomeçar</button>
                  </div>
                )}
              </div>

              <div style={{
                display: "flex", alignItems: "center", justifyContent: "space-between", padding: "8px",
                marginTop: 12, marginBottom: 12, gap: 8
              }}>
                <StatPill icon="🍎" value={stats.saciedade} hue="#FF8FA3" />
                <StatPill icon="❤️" value={stats.felicidade} hue="#FF6FA5" />
                <StatPill icon="☀️" value={stats.energia} hue="#FFC04D" />
                <StatPill icon="💧" value={stats.higiene} hue="#74C0FC" />
                <StatPill icon="💚" value={stats.saude} hue="#5FD0C5" />
              </div>

              <div style={{ display: "grid", gridTemplateColumns: "repeat(3, 1fr)", gap: 8 }}>
                <DeviceButton icon="🍎" label="Alimentar" color="#FF8FA3" onClick={feed} disabled={busy} />
                <DeviceButton icon="🎮" label="Brincar" color="#5FD0C5" onClick={playGame} disabled={busy} />
                <DeviceButton icon={sleeping ? "☀️" : "🌙"} label={sleeping ? "Acordar" : "Dormir"} color="#9B8CFF" onClick={toggleSleep} disabled={!alive} />
                <DeviceButton icon="💧" label="Limpar" color="#74C0FC" onClick={clean} disabled={busy} />
                <DeviceButton icon="💕" label="Carinho" color="#FF6FA5" onClick={pet} disabled={busy} />
                <DeviceButton icon="ℹ️" label="Info" color="#FFC04D" onClick={() => showMsg(`${ageS}s vivo!`)} disabled={!alive} />
              </div>
            </div>

            <p style={{
              textAlign: "center", marginTop: 16, fontSize: 11, color: "#6b5f9e", fontWeight: 600
            }}>Toque no bichinho pra interagir</p>
          </div>
        </div>
      );
    }

    ReactDOM.createRoot(document.getElementById('root')).render(<BichoVivo />);
  </script>
</body>
</html>
